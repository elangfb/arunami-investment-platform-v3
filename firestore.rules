rules_version = '2';

// Deny-all for the client SDK. Every read/write in Mizan goes through the Next.js server
// using the Firebase Admin SDK, which BYPASSES these rules entirely. No browser/client path
// ever touches Firestore directly, so locking the client surface to zero is the intended,
// safe posture — and the compliance backstop for the append-only audit collections
// (applications/*/history, decisionCheckpoints, aiInteractions): no client path can mutate them.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
