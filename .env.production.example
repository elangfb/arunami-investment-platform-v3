# Mizan production env. Copy to `.env` (compose's default file — used for BOTH ${...}
# interpolation and as the containers' env_file):  cp .env.production.example .env
# Then fill every value. NEVER commit the filled `.env`.
#
# ⚠️ NEXT_PUBLIC_* are inlined into the browser bundle at BUILD time (passed as build
#    args by compose.build.yaml / GHCR workflow). If you change them you must rebuild: `--build`.
#    All other vars are read at runtime.

# ── Registry deploys (compose.ghcr.yaml / scripts/deploy-ghcr.sh) ─────────────
# GitHub Actions publishes images to: ghcr.io/<owner>/mizan-{web,migrate}.
# The script defaults IMAGE_TAG to `main`; pass a commit SHA/tag to deploy an immutable build.
GHCR_IMAGE_PREFIX=ghcr.io/CHANGE_ME_OWNER
IMAGE_TAG=main

# ── Reverse proxy / TLS ───────────────────────────────────────────────────────
# localhost → Caddy local cert (LAN/dev). A real FQDN → auto-HTTPS (needs 80/443
# reachable + DNS), or mount the bank's own cert (see docker/Caddyfile).
DOMAIN=localhost

# ── PostgreSQL (the `postgres` service reads these; DATABASE_URL must match) ───
POSTGRES_USER=mizan
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=mizan
DATABASE_URL=postgresql://mizan:CHANGE_ME_STRONG_DB_PASSWORD@postgres:5432/mizan?schema=public
# Optional pool tuning (defaults shown). Keep DATABASE_POOL_MAX ≤ Postgres max_connections.
# DATABASE_POOL_MAX=10
# DATABASE_CONNECT_TIMEOUT_MS=10000

# ── Document object storage (the `seaweedfs` service; keys must match docker/seaweedfs/s3.json) ──
S3_ENDPOINT=http://seaweedfs:8333
S3_REGION=us-east-1
S3_BUCKET=mizan-docs
S3_ACCESS_KEY=CHANGE_ME_ACCESS_KEY
S3_SECRET_KEY=CHANGE_ME_SECRET_KEY

# ── Firebase Auth ─────────────────────────────────────────────────────────────
# Public client config (BUILD-time — see warning above).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Server Admin SDK service account (mints session cookies): base64 of the JSON, or a path.
FIREBASE_SERVICE_ACCOUNT=
# Comma-separated emails auto-elevated to Superadmin on first login.
SUPERADMIN_EMAILS=
SESSION_COOKIE_NAME=mizan-session
IMPERSONATE_COOKIE_NAME=mizan-impersonate

# ── Google Docs/Drive (MUAP/RSK source-of-truth) ─────────────────────────────
# NOTE: requires outbound egress to Google. Gated on the bank-egress ruling — if the
# bank forbids on-prem→internet, this whole integration needs rework (see docs).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://localhost/oauth2callback
GOOGLE_REFRESH_TOKEN=
GOOGLE_MASTER_MUAP_DOC_ID=
GOOGLE_MASTER_RSK_DOC_ID=

# ── AI (Vertex / Gemini) ──────────────────────────────────────────────────────
# Requires outbound egress (same gate). Without Vertex configured, AI falls back to
# deterministic synthesis. PII is masked before every call (lib/pii-mask.ts).
# Vertex is the SOLE provider (the AI Studio GEMINI_API_KEY path was dropped 2026.06.08).
GEMINI_MODEL=gemini-3.5-flash
GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=asia-southeast1   # default asia-southeast1 (Singapore, APAC). Out-of-region
#   (incl. `global`, US-served) is PERMITTED but WARNS (ai.region_out_of_apac) — accepted interim,
#   egresses Bank PII outside APAC; revisit for prod / before 17 Dec 2026 (OJK §27 in-region).
# Vertex auth (value-based, like DOCUMENTAI_CREDENTIALS): base64 SA JSON with roles/aiplatform.user.
# Unset → reuse same-project FIREBASE_SERVICE_ACCOUNT, else ADC.
# VERTEX_CREDENTIALS=
#
# PII residual backstop (server/ai/redact.ts): masking ALWAYS runs; this gates the fallback when
# a residual identifier survives. PROD handling real customer data should FAIL CLOSED. See
# docs/designs/pii-masking.md.
PII_RESIDUAL_BLOCK=1

# ── Web research (SearXNG + Firecrawl; containers always run in compose.shared.yaml) ──
# Leave provider/worker unset to keep app-side research disabled while the local services run.
# Enable only when outbound web-search/scrape egress is approved.
SEARXNG_SECRET=CHANGE_ME_SEARXNG_SECRET_HEX
# WEB_RESEARCH_PROVIDER=searxng-firecrawl
# RESEARCH_WORKER_ENABLED=1
# SEARXNG_URL=http://searxng:8080
# FIRECRAWL_URL=http://firecrawl:3002
# FIRECRAWL_API_KEY=

# ── OCR (document extraction) ─────────────────────────────────────────────────
# Which OCR engine reads uploaded KTP/SLIK docs. 'stub' (default) = offline fabrication
# (no egress, dev/safe). 'gemini' = external Gemini multimodal (sends the document image to
# Google — needs the Vertex config above + the egress+DPA posture). Swap to a self-hosted
# 'local'/'documentai' provider here once implemented (server/ocr) — no code change at call sites.
OCR_PROVIDER=stub

# ── Observability ─────────────────────────────────────────────────────────────
# Structured JSON logs go to stdout/stderr (collect via the container runtime).
# Level threshold: debug | info | warn | error (default info). debug also emits stack traces.
LOG_LEVEL=info
