# Google Docs/Drive integration — OAuth with a DEDICATED Mizan Google account.
# Copy this file to `.env.local` and fill it in. .env.local is gitignored.
#
# Setup (full guide: docs/guides/google-docs-oauth.md):
#   1. Create a dedicated Google account for the app (e.g. mizan.app.docs@gmail.com).
#      DO NOT use a real person's Gmail — the account is "Mizan the app", set-and-forget.
#      The account's 15 GB free Drive hosts every per-app MUAP/RSK Doc.
#   2. In Google Cloud Console (https://console.cloud.google.com):
#      - Pick or create a project.
#      - Enable Google Docs API + Google Drive API.
#      - OAuth consent screen → External → add the dedicated Mizan account as a Test user.
#      - Credentials → Create OAuth client → "Web application".
#        Authorized redirect URI (exactly): http://localhost:53682/oauth2callback
#      - Copy Client ID / Client secret below.
#   3. From repo root run:  pnpm google:auth
#      Opens a consent URL in the browser — sign in with the dedicated Mizan account,
#      approve the scopes (documents + drive). The script writes GOOGLE_REFRESH_TOKEN
#      back into .env.local automatically.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:53682/oauth2callback
GOOGLE_REFRESH_TOKEN=

# Master template Google Doc IDs (v1 + v2). Filled after creating the masters in the
# dedicated Mizan account's Drive (or sharing existing ones to that account).
GOOGLE_MASTER_MUAP_DOC_ID=
GOOGLE_MASTER_RSK_DOC_ID=
GOOGLE_MASTER_MUAP_V2_DOC_ID=
GOOGLE_MASTER_RSK_V2_DOC_ID=

# Prisma/PostgreSQL. Local dev: a postgres reachable at this URL. Run migrations
# from repo root with env loaded:
#   set -a; . apps/web-app/.env.local; set +a; ./apps/web-app/node_modules/.bin/prisma migrate dev
# Seed (from apps/web-app, so tsx resolves @/* paths):
#   cd apps/web-app && set -a; . .env.local; set +a; pnpm exec tsx prisma/seed.ts
DATABASE_URL=postgresql://postgres:password@localhost:5432/mizan?schema=public

# AI (Vertex). Vertex is the SOLE provider (the AI Studio GEMINI_API_KEY path was dropped
# 2026.06.08 to remove the silent-precedence footgun). Set GOOGLE_CLOUD_PROJECT to enable AI;
# without it the AI chat falls back to deterministic synthesis.
# Default model is gemini-3.5-flash (GA Flash; single model across narrative / analysis /
# chat / research synthesis / OCR-via-gemini). Override GEMINI_MODEL for new tags or A/B.
GEMINI_MODEL=gemini-3.5-flash
GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=asia-southeast1  # default Singapore (APAC). Out-of-region incl. `global`
#   (US-served) is PERMITTED but WARNS (ai.region_out_of_apac) — accepted interim, egresses PII
#   outside APAC; revisit for prod / before 17 Dec 2026 (OJK §27).
# Vertex auth: base64 of a service-account JSON with roles/aiplatform.user (value-based, like
# DOCUMENTAI_CREDENTIALS). If unset, the same-project FIREBASE_SERVICE_ACCOUNT is reused, else ADC
# (gcloud auth application-default login).
# VERTEX_CREDENTIALS=
#
# PII residual backstop policy (server/ai/redact.ts). The egress layer ALWAYS masks PII; this
# only controls what happens if a residual structured identifier survives masking. Default
# (unset) = fail-OPEN: log `pii.residual_detected` but still egress (keeps demos unblocked).
# Set to 1 for prod / real customer data to FAIL CLOSED. See docs/designs/pii-masking.md.
# PII_RESIDUAL_BLOCK=1

# ── OCR provider (server/ocr) ────────────────────────────────────────────────
# Selects the OCR engine. Unset/'stub' = offline fabrication (dev/test/CI, no egress).
# 'documentai' = PRODUCTION engine (Google Document AI; dedicated processor + confidence).
# 'gemini' = interim cloud OCR (generative; sends the raw image to the model).
# OCR_PROVIDER=documentai
#
# Document AI config (only when OCR_PROVIDER=documentai). Setup: see docs/guides/document-ai-ocr.md
#   1. GCP console → enable the Document AI API.
#   2. Create a "Document OCR" processor → note its ID + region (us/eu).
#   3. Create a service account with role "Document AI API User"; download its JSON key.
#   4. Base64 the JSON for DOCUMENTAI_CREDENTIALS:  base64 -w0 sa-key.json
# DOCUMENTAI_PROJECT_ID=
# DOCUMENTAI_LOCATION=asia-southeast1   # Singapore — nearest region to Indonesia (data residency + latency). 'us'/'eu' also valid.
# DOCUMENTAI_PROCESSOR_ID=
# DOCUMENTAI_CREDENTIALS=        # base64 SA JSON; if unset, falls back to FIREBASE_SERVICE_ACCOUNT (same project) then ADC

# ── Firebase Auth (Phase 2: real Google login) ───────────────────────────────
# Client SDK config (public — exposed to the browser). From Firebase console →
# Project settings → Your apps → SDK setup and configuration.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Server Admin SDK service-account key (mints session cookies). Path to the JSON
# OR base64 of its contents. Firebase console → Project settings → Service accounts.
FIREBASE_SERVICE_ACCOUNT=
# Comma-separated emails auto-elevated to Superadmin on first login.
SUPERADMIN_EMAILS=
SESSION_COOKIE_NAME=mizan-session

# ── Firebase backend migration (Firestore + Cloud Storage) ──────────────────────────
# Data backend selector: 'prisma' (Postgres, default/today), 'firestore' (Cloud Firestore),
# or 'dual' (Prisma authoritative + Firestore shadow-write, for parity soak before cutover).
DATA_BACKEND=prisma
# Object storage backend: 's3' (SeaweedFS/S3, default), 'firebase' (Cloud Storage), 'stub' (tests).
STORAGE_PROVIDER=s3
# Cloud Storage bucket when STORAGE_PROVIDER=firebase (else derived from FIREBASE_PROJECT_ID).
FIREBASE_STORAGE_BUCKET=
# GCP/Firebase project id (Admin SDK + Cloud Storage bucket derivation).
FIREBASE_PROJECT_ID=
# Shared secret for scheduled trigger endpoints (/api/cron/*), sent by Cloud Scheduler as a
# Bearer token. REQUIRED for the meeting materializer cron to run (fail-closed if unset).
# See docs/guides/firebase-background-jobs.md.
CRON_SECRET=
# Research worker: '1' starts the background poller (opt-in); unset = disabled.
RESEARCH_WORKER_ENABLED=
